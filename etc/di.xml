<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Logger -->
    <virtualType name="Byte8\PingBell\Logger\Handler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/pingbell.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="Byte8\PingBell\Logger\Logger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">byte8_pingbell</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Byte8\PingBell\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Inject logger into PingBellClient -->
    <type name="Byte8\PingBell\Model\PingBellClient">
        <arguments>
            <argument name="logger" xsi:type="object">Byte8\PingBell\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- Inject logger into base observer -->
    <type name="Byte8\PingBell\Observer\SendPingBellNotification">
        <arguments>
            <argument name="logger" xsi:type="object">Byte8\PingBell\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- Event-specific observer virtual types -->
    <virtualType name="Byte8\PingBell\Observer\SendNewOrderNotification" type="Byte8\PingBell\Observer\SendPingBellNotification">
        <arguments>
            <argument name="eventKey" xsi:type="string">new_order</argument>
        </arguments>
    </virtualType>

    <virtualType name="Byte8\PingBell\Observer\SendNewInvoiceNotification" type="Byte8\PingBell\Observer\SendPingBellNotification">
        <arguments>
            <argument name="eventKey" xsi:type="string">new_invoice</argument>
        </arguments>
    </virtualType>

    <virtualType name="Byte8\PingBell\Observer\SendNewShipmentNotification" type="Byte8\PingBell\Observer\SendPingBellNotification">
        <arguments>
            <argument name="eventKey" xsi:type="string">new_shipment</argument>
        </arguments>
    </virtualType>

    <virtualType name="Byte8\PingBell\Observer\SendNewCreditmemoNotification" type="Byte8\PingBell\Observer\SendPingBellNotification">
        <arguments>
            <argument name="eventKey" xsi:type="string">new_creditmemo</argument>
        </arguments>
    </virtualType>

    <virtualType name="Byte8\PingBell\Observer\SendNewCustomerNotification" type="Byte8\PingBell\Observer\SendPingBellNotification">
        <arguments>
            <argument name="eventKey" xsi:type="string">new_customer</argument>
        </arguments>
    </virtualType>

    <!-- Activation: bind PingBell's product_id + config path prefix to the
         shared Byte8\Activation\Model\Activation gate. The empty subclass
         Model/Activation/Activation.php exists as a type-hint anchor. -->
    <type name="Byte8\PingBell\Model\Activation\Activation">
        <arguments>
            <argument name="productId" xsi:type="string">pingbell</argument>
            <argument name="configPathPrefix" xsi:type="string">byte8_pingbell/activation/</argument>
        </arguments>
    </type>

    <!-- CLI registration -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="byte8_pingbell_activate" xsi:type="object">Byte8\PingBell\Console\Command\ActivateCommand</item>
            </argument>
        </arguments>
    </type>
</config>
