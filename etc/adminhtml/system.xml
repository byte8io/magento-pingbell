<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="byte8_pingbell" translate="label" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
            <label>PingBell Notifications</label>
            <tab>byte8</tab>
            <resource>Byte8_PingBell::config</resource>

            <group id="activation" translate="label comment" type="text" sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Activation</label>
                <comment><![CDATA[The module ships free and open-source on Packagist. To activate it, get a free activation key at <a href="https://byte8.io/activate/pingbell" target="_blank">byte8.io/activate/pingbell</a> and paste it below. Without a key, PingBell notifications are silently skipped.]]></comment>

                <field id="key" translate="label comment" type="obscure" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Activation Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Format: <code>b8a_pb_<32 hex chars></code>. Stored encrypted via Magento's standard encryption.]]></comment>
                </field>

                <field id="endpoint" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Verify Endpoint</label>
                    <comment><![CDATA[Default <code>https://api.byte8.io/graphql</code>. Override only for staging / development.]]></comment>
                </field>

                <field id="timeout" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Verify Timeout (seconds)</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Hard response timeout for the verify call. Default 5s. Verify fires at most once per 24h.</comment>
                </field>

                <field id="connect_timeout" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Verify Connect Timeout (seconds)</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>TCP/TLS connect timeout for the verify call. Default 2s.</comment>
                </field>
            </group>

            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General Settings</label>

                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enable PingBell Notifications</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Send notifications to PingBell for configured events.</comment>
                </field>

                <field id="api_key" translate="label comment" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Your PingBell API key. Find it at app.pingbell.io.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <group id="events" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Event Notifications</label>
                <comment>Configure which PingBell to notify for each event. Leave the PingBell ID empty to disable notification for that event.</comment>
                <depends>
                    <field id="byte8_pingbell/general/enabled">1</field>
                </depends>

                <field id="new_order_pingbell_id" translate="label comment" type="text" sortOrder="100" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>New Order</label>
                    <comment>Notified when a new order is placed.</comment>
                    <frontend_model>Byte8\PingBell\Block\Adminhtml\System\Config\FetchBells</frontend_model>
                </field>

                <field id="new_invoice_pingbell_id" translate="label comment" type="text" sortOrder="200" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>New Invoice</label>
                    <comment>Notified when a new invoice is created.</comment>
                    <frontend_model>Byte8\PingBell\Block\Adminhtml\System\Config\FetchBells</frontend_model>
                </field>

                <field id="new_shipment_pingbell_id" translate="label comment" type="text" sortOrder="300" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>New Shipment</label>
                    <comment>Notified when a new shipment is created.</comment>
                    <frontend_model>Byte8\PingBell\Block\Adminhtml\System\Config\FetchBells</frontend_model>
                </field>

                <field id="new_creditmemo_pingbell_id" translate="label comment" type="text" sortOrder="400" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>New Credit Memo</label>
                    <comment>Notified when a new credit memo is created.</comment>
                    <frontend_model>Byte8\PingBell\Block\Adminhtml\System\Config\FetchBells</frontend_model>
                </field>

                <field id="new_customer_pingbell_id" translate="label comment" type="text" sortOrder="500" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>New Customer Registration</label>
                    <comment>Notified when a new customer registers.</comment>
                    <frontend_model>Byte8\PingBell\Block\Adminhtml\System\Config\FetchBells</frontend_model>
                </field>
            </group>
        </section>
    </system>
</config>
